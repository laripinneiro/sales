                <elementReference>ObterCasosCollection</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Caso</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Add_Info_Casos</name>
