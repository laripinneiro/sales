            </value>
        </assignmentItems>
        <connector>
            <targetReference>Apenas_1_ou_Mais</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Preenche_assunto</name>
        <label>Preenche assunto</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>Loop_Obter_Casos.Subject</assignToReference>
            <operator>Assign</operator>
