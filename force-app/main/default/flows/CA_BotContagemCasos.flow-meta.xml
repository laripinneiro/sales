                <stringValue>Sem assunto</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Obter_Casos</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Apenas_1_ou_Mais</name>
        <label>Apenas 1 ou Mais</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Casos</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default outcome</defaultConnectorLabel>
        <rules>
            <name>X1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>QtdCasos</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Caso</targetReference>
            </connector>
            <label>1</label>
        </rules>
    </decisions>
    <decisions>
        <name>Assunto_esta_preenchido</name>
        <label>Assunto está preenchido?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Preenche_assunto</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Vazio</defaultConnectorLabel>
        <rules>
            <name>Preenchido</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Obter_Casos.Subject</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Obter_Casos</targetReference>
            </connector>
            <label>Preenchido</label>
        </rules>
    </decisions>
    <description>Atualiza o GetRecords: Case.Status != &apos;Finalizado&apos; | Retira do GetRecords: Case.Subject != &apos;&apos;</description>
    <environments>Default</environments>
    <formulas>
        <name>FormulaHoje</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <formulas>
        <name>FormulaListaCasos</name>
        <dataType>String</dataType>
        <expression>{!Loop_Casos.CaseNumber}+&quot; - &quot;+{!Loop_Casos.Subject}+BR()</expression>
    </formulas>
    <formulas>
        <name>FormulaStatus</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!Loop_Caso.Status})=&quot;New&quot;, &quot;Novo&quot;,
    IF(TEXT({!Loop_Caso.Status})=&quot;On Hold&quot;, &quot;Em espera&quot;,
       IF(TEXT({!Loop_Caso.Status})=&quot;Closed&quot;, &quot;Fechado&quot;,
          IF(TEXT({!Loop_Caso.Status})=&quot;Escalated&quot;, &quot;Escalado&quot;,
            IF(TEXT({!Loop_Caso.Status})=&quot;Critical&quot;, &quot;Critical&quot;,
         &quot;&quot;)
          )
       )
   )
)</expression>
    </formulas>
    <interviewLabel>[Bot] Contagem Casos {!$Flow.CurrentDateTime}</interviewLabel>
    <label>[Bot] Contagem Casos</label>
    <loops>
        <name>Loop_Caso</name>
        <label>Loop Caso</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>ObterCasosCollection</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Info_Caso</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
