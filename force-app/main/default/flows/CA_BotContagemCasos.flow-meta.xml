        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Info_Casos</targetReference>
        </nextValueConnector>
    </loops>
    <loops>
        <name>Loop_Obter_Casos</name>
        <label>Loop Obter Casos</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>ObterCasosCollection</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assunto_esta_preenchido</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Contagem_Casos</targetReference>
        </noMoreValuesConnector>
    </loops>
