<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Atribui_fila_e_description</name>
        <label>Atribui fila (output) e nova descrição (para concatenar)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>fila</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Obtem_o_caso_selecionado.OwnerId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>oldDescription</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Obtem_o_caso_selecionado.Description</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Atualiza_descri_o</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Copy_2_of_Atribui_fila_output_e_nova_descri_o_para_concatenar</name>
        <label>Atribui fila de MS (output) e nova descrição (para concatenar)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>fila</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Obtem_Fila.Messaging_Queue_Id__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>oldDescription</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Obtem_o_caso_selecionado.Description</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Atualiza_descri_o</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>O_Owner_fila_ou_usuario</name>
        <label>O Owner é fila ou usuário?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Atribui_fila_e_description</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>É usuário</defaultConnectorLabel>
        <rules>
            <name>E_fila</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Obtem_o_caso_selecionado.OwnerId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>00G</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Obtem_Fila</targetReference>
            </connector>
            <label>É fila</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>concatenatedDescription</name>
        <dataType>String</dataType>
        <expression>{!oldDescription} + &apos; &apos; + TEXT(DATETIMEVALUE({!$Flow.CurrentDateTime})) + {!newDescriptionToAdd}</expression>
    </formulas>
    <interviewLabel>[Bot] Obter agente responsável pelo caso {!$Flow.CurrentDateTime}</interviewLabel>
    <label>[Bot] Obter agente responsável pelo caso</label>
    <processMetadataValues>
        <name>BuilderType</name>
