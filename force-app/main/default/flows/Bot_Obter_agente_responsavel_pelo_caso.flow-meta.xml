    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Obtem_Fila</name>
        <label>Obtem CMT</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Copy_2_of_Atribui_fila_output_e_nova_descri_o_para_concatenar</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>CaseQueue_Label__c</field>
