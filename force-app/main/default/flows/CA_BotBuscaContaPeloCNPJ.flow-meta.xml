    <formulas>
        <name>CpfNormalizado</name>
        <dataType>String</dataType>
        <expression>TRIM(
    SUBSTITUTE(
        SUBSTITUTE(
            SUBSTITUTE(
                SUBSTITUTE({!CPFCNPJ}, &quot;.&quot;, &quot;&quot;), 
            &quot;/&quot;, &quot;&quot;),
        &quot;-&quot;, &quot;&quot;),
    &quot; &quot;, &quot;&quot;)
)</expression>
    </formulas>
    <formulas>
        <name>FormulaMascaraEmail</name>
        <dataType>String</dataType>
        <expression>LEFT({!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c}, 3) &amp;
LEFT(&quot;************************************************************************************************************&quot;, FIND(&quot;@&quot;, {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c}) - 3) &amp;
&quot;@&quot; &amp;
LEFT(&quot;************************************************************************************************************&quot;, FIND(&quot;.&quot;, {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c}, FIND(&quot;@&quot;, {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c})) - FIND(&quot;@&quot;, {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c}) - 1) &amp;
RIGHT(
  {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c},
  LEN({!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c}) -
  FIND(&quot;.&quot;, {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c}, FIND(&quot;@&quot;, {!Obter_Conta_Pelo_CPFCNPJ.CA_Email__c})) + 1
)</expression>
    </formulas>
    <formulas>
