        <expression>MID({!Obter_Sessao_do_Messaging.MessagingEndUser.MessagingPlatformKey}, 3 , LEN({!Obter_Sessao_do_Messaging.MessagingEndUser.MessagingPlatformKey}) - 2 )</expression>
    </formulas>
