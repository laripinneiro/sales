            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Check_contract_end_date</name>
        <label>Check contract end date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>beforeToday_false</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>after today</defaultConnectorLabel>
        <rules>
            <name>before_today</name>
            <conditionLogic>1 AND 2</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contract.CA_DataFinal__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>today</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Contract.CA_DataFinal__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_EnderecoFormatado_to_imovel_and_isBeforeToday</targetReference>
            </connector>
            <label>before today</label>
        </rules>
        <rules>
            <name>before_today_is_null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Contract.CA_DataFinal__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_1_of_beforeToday_false</targetReference>
            </connector>
            <label>before today is null</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>imovelEnderecoFormula</name>
        <dataType>String</dataType>
        <expression>{!Get_Imovel.CA_Endereco__Street__s} + 
IF(ISBLANK({!Get_Imovel.CA_NumeroEndereco__c}), &quot;&quot;, &quot;, &quot; + {!Get_Imovel.CA_NumeroEndereco__c}) + 
IF(ISBLANK({!Get_Imovel.CA_Complemento__c}), &quot;&quot;, &quot; - &quot; + {!Get_Imovel.CA_Complemento__c}) + 
IF(ISBLANK({!Get_Imovel.CA_Bairro__c}), &quot;&quot;, &quot; - &quot; + {!Get_Imovel.CA_Bairro__c}) + &quot;, &quot; +
{!Get_Imovel.CA_Endereco__City__s}</expression>
    </formulas>
    <formulas>
        <name>today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>[Bot] Check Contract End Date {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Verifica a data final do contrato e obtem o endereço do imovel do contrato</label>
