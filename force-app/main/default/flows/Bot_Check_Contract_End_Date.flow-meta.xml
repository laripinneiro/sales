    <assignments>
        <name>Assign_EnderecoFormatado_to_imovel_and_isBeforeToday</name>
        <label>Assign EnderecoFormatado to imovel and isBeforeToday</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>isBeforeToday</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>imovelEnderecoFormatado</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>imovelEnderecoFormula</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>beforeToday_false</name>
        <label>beforeToday = false</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>isBeforeToday</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>imovelEnderecoFormatado</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>imovelEnderecoFormula</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Copy_1_of_beforeToday_false</name>
        <label>beforeToday = false</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>isBeforeToday</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
